{
  "name": "solidtime-cli",
  "version": "0.1.1",
  "description": "Timer-first CLI for solidtime",
  "type": "module",
  "main": "./dist/solidtime.js",
  "bin": {
    "solidtime": "./dist/solidtime.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "bun run index.ts",
    "build": "rm -rf dist && bun build ./index.ts --target node --outfile ./dist/solidtime.js && chmod +x ./dist/solidtime.js",
    "typecheck": "tsc --noEmit",
    "prepack": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "dependencies": {
    "@solidtime/api": "^0.0.6",
    "@stricli/core": "^1.2.6"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mathiasandresen/solidtime-cli.git"
  },
  "bugs": {
    "url": "https://github.com/mathiasandresen/solidtime-cli/issues"
  },
  "homepage": "https://github.com/mathiasandresen/solidtime-cli#readme"
}
